---
import '../styles/global.css';
import '../styles/custom.css';
import { ChatbotWidget } from '../components/ChatbotWidget';

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { title, description = "Soluciones digitales para un mundo dinámico. Desarrollo fullstack con enfoque en resultados operativos.", image = "/img/Open Graph.png" } = Astro.props;

// URL base del sitio configurada en astro.config.mjs
const siteUrl = 'https://jorge-cabrera.cl';
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).href;
const ogImageUrl = new URL(image, siteUrl).href;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/img/Logo aperca oscuro.svg" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- SEO -->
    <title>{title}</title>
    <link rel="canonical" href={canonicalUrl} />
    
    <!-- Open Graph / WhatsApp / Facebook -->
    <meta property="og:site_name" content="Jorge Cabrera - Desarrollo Fullstack" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />
    <meta property="og:locale" content="es_CL" />
    
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={title} />
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@700;900&family=Syne:wght@800&family=Special+Elite&family=Poppins:wght@400;600;700&family=Playfair+Display:wght@600&display=swap" rel="stylesheet">
    
    <style>
      * {
        box-sizing: border-box;
      }
      
      html, body {
        margin: 0;
        padding: 0;
        width: 100%;
        height: 100%;
      }
      
      img {
        max-width: 100%;
        height: auto;
      }
    </style>
  </head>
  <body class="bg-[#FAF9F6] text-neutral-950 antialiased">
    <slot />
    
    <!-- Chatbot flotante - Cargado con client:idle para no afectar Core Web Vitals -->
    <ChatbotWidget client:idle />
  </body>
</html>
