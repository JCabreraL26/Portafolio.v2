          'arch-backend-title': '📦 Backend (Supabase/PostgreSQL)',
          'arch-backend-desc': 'Base de datos relacional con políticas RLS (seguridad a nivel de fila) para proteger la integridad de la información sensible',
          'arch-audit-title': '📋 Lógica de Auditoría',
          'arch-audit-desc': 'Registro automático de transacciones y motor de normalización de stock para eliminar el cálculo mental del operario',
          'arch-deploy-title': '🚀 Despliegue',
          'arch-deploy-desc': 'CI/CD en Netlify con carga optimizada (< 2s) para un uso móvil intensivo y fluido',
          'results-title': '🔴 Resultados',
          'results-precision': 'Precisión',
          'results-precision-desc': 'Eliminación total de descuadres entre factura y bodega',
          'results-efficiency': 'Eficiencia',
          'results-efficiency-desc': 'Reducción del tiempo en el registro de movimientos',
          'results-control': 'Control',
          'results-control-desc': 'Trazabilidad completa de la operación desde el bolsillo del cliente',
